{
  "name": "wowclean-frontend",
  "version": "1.0.0",
  "description": "A frontend for WowClean React app.",
  "dependencies": {
    "@cloudinary/react": "^1.13.1",
    "@cloudinary/url-gen": "^1.21.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "axios": "^1.7.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "^3.0.1",
    "socket.io-client": "^4.8.1"
  },
  "scripts": {
  "start": "export NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
  "build": "export NODE_OPTIONS=--openssl-legacy-provider && react-scripts build",
  "deploy": "npm run build && aws s3 sync build/ s3://wowcleanpt-frontend --delete && aws cloudfront create-invalidation --distribution-id EUF2CKAAI3W6F --paths '/*'",
  "test": "react-scripts test",
  "eject": "react-scripts eject"
},
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "18.x",
    "npm": "8.x"
  }
}
